        <!-- ==================== Annotations ==================== -->
        <!-- Computation box -->
        <mxCell id="400" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="270" width="560" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="401" value="&lt;b&gt;计算示例: o₁₂ 是怎么得到的？&lt;/b&gt;" style="text;html=1;fontSize=14;align=left;" vertex="1" parent="1">
          <mxGeometry x="45" y="280" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="402" value="o₁₂ = α 的第 1 行 × V 的第 2 列&lt;br&gt;&lt;br&gt;= α₁₀ × v₀₂ + α₁₁ × v₁₂ + α₁₂ × v₂₂ + α₁₃ × v₃₂&lt;br&gt;&lt;br&gt;= T 次乘法 + (T-1) 次加法 ≈ &lt;b&gt;2T FLOPs&lt;/b&gt;" style="text;html=1;fontSize=12;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="45" y="310" width="500" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="403" value="&lt;b&gt;含义:&lt;/b&gt; o₁₂ = 所有 token 的 value 第 2 维的加权和，权重就是 token 1 的注意力分布&lt;br&gt;即 &lt;b&gt;token 1 从所有 token 收集的第 2 维信息&lt;/b&gt;" style="text;html=1;fontSize=12;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="45" y="405" width="530" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="404" value="展开来看 += 操作 (这就是 2D FLOPs 中加法的来源):&lt;br&gt;&lt;br&gt;o₁₂  = 0&lt;br&gt;o₁₂ += α₁₀ × v₀₂&amp;nbsp;&amp;nbsp;&amp;nbsp;← 1次乘 + 1次加&lt;br&gt;o₁₂ += α₁₁ × v₁₂&amp;nbsp;&amp;nbsp;&amp;nbsp;← 1次乘 + 1次加&lt;br&gt;o₁₂ += α₁₂ × v₂₂&amp;nbsp;&amp;nbsp;&amp;nbsp;← 1次乘 + 1次加&lt;br&gt;o₁₂ += α₁₃ × v₃₂&amp;nbsp;&amp;nbsp;&amp;nbsp;← 1次乘 + 1次加" style="text;html=1;fontSize=11;align=left;verticalAlign=top;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="45" y="445" width="380" height="130" as="geometry"/>
        </mxCell>

        <!-- FLOPs summary box -->
        <mxCell id="410" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="620" y="270" width="270" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="411" value="&lt;b&gt;O 矩阵每个元素的含义&lt;/b&gt;" style="text;html=1;fontSize=13;align=left;" vertex="1" parent="1">
          <mxGeometry x="635" y="280" width="240" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="412" value="• 行 i = 第 i 个 token 的输出&lt;br&gt;• 列 d = 输出的第 d 个维度&lt;br&gt;• O[i][d] = 所有 token 第 d 维 value&lt;br&gt;&amp;nbsp;&amp;nbsp;的加权和 (权重 = token i 的注意力)" style="text;html=1;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="635" y="305" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="413" value="&lt;b&gt;按 (i,j) attention 点拆分 FLOPs:&lt;/b&gt;&lt;br&gt;&lt;br&gt;对于每个 (i,j)，要对 D 个维度做:&lt;br&gt;&amp;nbsp;&amp;nbsp;o_i[d] += α_ij × v_j[d]&lt;br&gt;&lt;br&gt;= D 次乘法 + D 次加法 = &lt;b&gt;2D&lt;/b&gt;&lt;br&gt;&lt;br&gt;共 T² 个 (i,j) 点&lt;br&gt;&lt;b&gt;Step 2 总计: 2T²D = 96 FLOPs&lt;/b&gt;" style="text;html=1;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="635" y="380" width="240" height="140" as="geometry"/>
        </mxCell>

        <!-- Arrows from highlighted elements to computation -->
        <mxCell id="430" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;dashed=1;" edge="1" source="114" target="400" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="431" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;dashed=1;" edge="1" source="212" target="400" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="432" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#CC0000;dashed=1;" edge="1" source="315" target="400" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- resize page to fit annotation -->
        <!-- Summary at bottom -->
        <mxCell id="500" value="Step 1 (2T²D) + Step 2 (2T²D) = &lt;b&gt;4T²D = 4 × 16 × 3 = 192 FLOPs&lt;/b&gt; (单head)    |    每个 attention 点: &lt;b&gt;4D FLOPs&lt;/b&gt; (2D来自Step1 + 2D来自Step2)" style="text;html=1;fontSize=12;align=center;fontColor=#CC0000;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="600" width="800" height="25" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
