<mxfile>
  <diagram name="Attention Overview" id="overview">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="600">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="2" value="Attention 计算流程 (单 Head, 单 Batch, T=4, D=3)" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- Q -->
        <mxCell id="3" value="Q&lt;br&gt;[T, D] = [4, 3]&lt;br&gt;&lt;font style='font-size:10px'&gt;每行 = 一个 token 的 query 向量&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- K^T -->
        <mxCell id="4" value="K^T&lt;br&gt;[D, T] = [3, 4]&lt;br&gt;&lt;font style='font-size:10px'&gt;每列 = 一个 token 的 key 向量&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- matmul 1 -->
        <mxCell id="5" value="matmul" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="160" width="90" height="40" as="geometry"/>
        </mxCell>

        <!-- FLOPs 1 -->
        <mxCell id="6" value="2T²D FLOPs&lt;br&gt;= 2×16×3 = 96" style="text;html=1;fontSize=11;fontColor=#CC0000;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="285" y="205" width="120" height="35" as="geometry"/>
        </mxCell>

        <!-- S -->
        <mxCell id="7" value="S = QK^T&lt;br&gt;[T, T] = [4, 4]&lt;br&gt;&lt;font style='font-size:10px'&gt;S[i][j] = token i 对 j 的关注度&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="470" y="100" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- softmax -->
        <mxCell id="8" value="softmax&lt;br&gt;(逐行归一化)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="490" y="220" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- alpha -->
        <mxCell id="9" value="α = softmax(S)&lt;br&gt;[T, T] = [4, 4]&lt;br&gt;&lt;font style='font-size:10px'&gt;每行之和 = 1，是概率分布&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="700" y="100" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- V -->
        <mxCell id="10" value="V&lt;br&gt;[T, D] = [4, 3]&lt;br&gt;&lt;font style='font-size:10px'&gt;每行 = 一个 token 的 value 向量&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="720" y="280" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- matmul 2 -->
        <mxCell id="11" value="matmul" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="990" y="200" width="90" height="40" as="geometry"/>
        </mxCell>

        <!-- FLOPs 2 -->
        <mxCell id="12" value="2T²D FLOPs&lt;br&gt;= 2×16×3 = 96" style="text;html=1;fontSize=11;fontColor=#CC0000;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="975" y="245" width="120" height="35" as="geometry"/>
        </mxCell>

        <!-- O -->
        <mxCell id="13" value="O = αV&lt;br&gt;[T, D] = [4, 3]&lt;br&gt;&lt;font style='font-size:10px'&gt;每行 = token 的加权输出&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="1150" y="190" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- Total FLOPs -->
        <mxCell id="14" value="总计算量 = 2T²D + 2T²D = 4T²D = 4×16×3 = 192 FLOPs (单head)" style="text;html=1;fontSize=13;fontColor=#CC0000;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="400" width="600" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="15" value="含 H 个 head 和 batch: 4BT²HD" style="text;html=1;fontSize=13;fontColor=#CC0000;align=center;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="430" width="600" height="30" as="geometry"/>
        </mxCell>

        <!-- Arrows -->
        <mxCell id="20" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="3" target="5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="21" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82b366;" edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="22" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" source="5" target="7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="23" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" source="7" target="8" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="24" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;" edge="1" source="8" target="9" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="25" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#9673a6;" edge="1" source="9" target="11" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="26" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#d6b656;" edge="1" source="10" target="11" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="27" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;" edge="1" source="11" target="13" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step labels -->
        <mxCell id="30" value="Step 1" style="text;html=1;fontSize=14;fontStyle=1;align=center;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="300" y="130" width="90" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="Step 2" style="text;html=1;fontSize=14;fontStyle=1;align=center;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="990" y="170" width="90" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
