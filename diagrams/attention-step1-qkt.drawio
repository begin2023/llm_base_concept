        <mxCell id="411" value="&lt;b&gt;计算示例: s₁₂ 是怎么得到的？&lt;/b&gt;" style="text;html=1;fontSize=14;fontStyle=0;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="55" y="300" width="350" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="412" value="s₁₂ = Q 的第 1 行 (q₁) · K^T 的第 2 列 (k₂) 做点积&lt;br&gt;&lt;br&gt;= q₁₀ × k₂₀ + q₁₁ × k₂₁ + q₁₂ × k₂₂&lt;br&gt;&lt;br&gt;= D 次乘法 + (D-1) 次加法 ≈ &lt;b&gt;2D FLOPs&lt;/b&gt;" style="text;html=1;fontSize=12;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="55" y="330" width="400" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="413" value="&lt;b&gt;含义:&lt;/b&gt; s₁₂ = token 1 的 query 和 token 2 的 key 的相似度&lt;br&gt;即 &lt;b&gt;token 1 对 token 2 的原始注意力分数&lt;/b&gt;" style="text;html=1;fontSize=12;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="55" y="425" width="500" height="35" as="geometry"/>
        </mxCell>

        <!-- FLOPs summary -->
        <mxCell id="420" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="620" y="240" width="320" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="421" value="&lt;b&gt;S 矩阵每个元素的含义&lt;/b&gt;" style="text;html=1;fontSize=13;align=left;" vertex="1" parent="1">
          <mxGeometry x="635" y="250" width="280" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="422" value="• 行 i = query 来自第 i 个 token&lt;br&gt;• 列 j = key 来自第 j 个 token&lt;br&gt;• S[i][j] = token_i 和 token_j 的相似度&lt;br&gt;&lt;br&gt;共 T×T = 16 个元素，每个 2D FLOPs&lt;br&gt;&lt;b&gt;Step 1 总计: 2T²D = 96 FLOPs&lt;/b&gt;" style="text;html=1;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="635" y="275" width="290" height="90" as="geometry"/>
        </mxCell>

        <!-- Arrow from highlighted row to computation -->
        <mxCell id="430" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;dashed=1;endArrow=block;" edge="1" source="113" target="410" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Arrow from highlighted col to computation -->
        <mxCell id="431" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D6B656;dashed=1;endArrow=block;" edge="1" source="212" target="410" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Arrow from s₁₂ to computation -->
        <mxCell id="432" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#CC0000;dashed=1;endArrow=block;" edge="1" source="326" target="410" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
